
font-family = Hasklug Nerd Font
font-size = 16

font-thicken = true

font-variation = "wght=420"
font-variation-bold = "wght=700"
font-variation-italic = "ital=1"

# cobalt2
background = #122738
foreground = #e6f3ff

palette = 0=#1c3b4d
palette = 1=#ff5c8a
palette = 2=#3aff88
palette = 3=#ffd166
palette = 4=#52a8ff
palette = 5=#c792ea
palette = 6=#4be3ff
palette = 7=#d6eaff

palette = 8=#5b7c95
palette = 9=#ff7aa2
palette = 10=#59ffa1
palette = 11=#ffe08a
palette = 12=#70b7ff
palette = 13=#d6a4ff
palette = 14=#6ff1ff
palette = 15=#ffffff


# Modern rendering options
unfocused-split-opacity = 0.8

# Window configuration
window-padding-x = 10
window-padding-y = 10
window-save-state = "always"
window-inherit-working-directory = true
window-inherit-font-size = true

# Shell and environment
copy-on-select = true
mouse-hide-while-typing = true
link-url = true
shell-integration-features = cursor, sudo, title

# Scrollback and history
scrollback-limit = 32000000

# Cursor customization
cursor-invert-fg-bg = true
cursor-style = "block"
cursor-style-blink = false
cursor-color = "#7aa2f7"


# Advanced features
macos-titlebar-style = transparent
confirm-close-surface = false

# Quick terminal feature
quick-terminal-position = "top"
quick-terminal-screen = "main"
quick-terminal-animation-duration = 200


# Clipboard
clipboard-read = "allow"
clipboard-write = "allow"
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# Background blur (macOS)
background-opacity = 0.9
background-blur-radius = 40

# Auto-update check
auto-update = "check"

# macOS-specific performance options
macos-option-as-alt = true
mouse-scroll-multiplier = 3


# Mouse
mouse-hide-while-typing = true
mouse-shift-capture = true

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

auto-update = check